<Page
    x:Class="FastAccountingSoftware.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title Header Row -->
            <RowDefinition Height="Auto"/> <!-- 4 Stats Cards Row -->
            <RowDefinition Height="Auto"/> <!-- Charts Row -->
            <RowDefinition Height="*"/>    <!-- Transactions Row -->
        </Grid.RowDefinitions>

        <!-- Row 0: Title Header & New Invoice Button -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Birthday Banner Notification Alert -->
            <Border x:Name="BirthdayBanner" Grid.Row="0" Grid.ColumnSpan="2" Background="#FFF9DB" BorderBrush="#FFE066" BorderThickness="1.5" CornerRadius="10" Padding="16,12" Margin="0,0,0,16" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🎉" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Customer Birthdays Today!" FontSize="14" FontWeight="Bold" Foreground="#F59F00"/>
                        <TextBlock x:Name="BirthdayBannerText" Text="Adaeze Adeola and 2 others are celebrating their birthday today." FontSize="12" Foreground="#858E96" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Send Wishes" Click="SendBulkDashboardWishes_Click" Background="#F59F00" Foreground="White" BorderThickness="0" Padding="14,6" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Cursor="Hand"/>
                </Grid>
            </Border>
            
            <StackPanel Grid.Row="1" Grid.Column="0">
                <TextBlock x:Name="GreetingText" Text="Good morning" FontFamily="Georgia, Serif" FontSize="36" FontWeight="Bold" Foreground="#1E3220" />
                <TextBlock x:Name="DateSubtitleText" Text="Here's where the firm's books stand today." FontSize="14" Foreground="#64748B" Margin="0,4,0,0" />
            </StackPanel>
            
            <!-- + New Invoice Button: Dark green background, rounded, bold text -->
            <Button Grid.Row="1" Grid.Column="1" Click="NewInvoice_Click" VerticalAlignment="Center" Height="42" Padding="20,0,20,0" 
                    Background="#1E4D2B" BorderThickness="0" md:ButtonAssist.CornerRadius="8" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="New invoice" FontSize="14" FontWeight="Bold" Foreground="White" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Row 1: The 4 Stats Cards (Cash on Hand, Outstanding Invoices, Payroll, Active Staff) -->
        <Grid Grid.Row="1" Margin="0,0,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card 1: Cash on Hand -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E1D6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.03"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="CASH ON HAND" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CashOnHandText" Text="₦0.00" FontFamily="Georgia, Serif" FontSize="26" FontWeight="Bold" Foreground="#1B2A1C" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▲" FontSize="10" Foreground="#10B981" VerticalAlignment="Center"/>
                        <TextBlock Text="4.2% vs last month" FontSize="12" Foreground="#64748B" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Card 2: Outstanding Invoices -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E1D6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.03"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="OUTSTANDING INVOICES" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <TextBlock x:Name="OutstandingInvoicesText" Text="₦0.00" FontFamily="Georgia, Serif" FontSize="26" FontWeight="Bold" Foreground="#1B2A1C" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▼" FontSize="10" Foreground="#EF4444" VerticalAlignment="Center"/>
                        <TextBlock Text="Active invoice balances" FontSize="12" Foreground="#B91C1C" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Card 3: Payroll Run - Jul -->
            <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E1D6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.03"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="PAYROLL RUN — JUL" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <TextBlock x:Name="PayrollRunText" Text="₦0.00" FontFamily="Georgia, Serif" FontSize="26" FontWeight="Bold" Foreground="#1B2A1C" Margin="0,0,0,8"/>
                    <TextBlock Text="Monthly staff payouts" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Active Staff -->
            <Border Grid.Column="6" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E1D6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.03"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="ACTIVE STAFF" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                    <TextBlock x:Name="ActiveStaffText" Text="0" FontFamily="Georgia, Serif" FontSize="26" FontWeight="Bold" Foreground="#1B2A1C" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▲" FontSize="10" Foreground="#10B981" VerticalAlignment="Center"/>
                        <TextBlock Text="On active duty" FontSize="12" Foreground="#64748B" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: Charts and AI Assistant Row -->
        <Grid Grid.Row="2" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Cash Flow Chart Widget -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E1D6" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.03"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cash flow — last 6 months" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="10" Height="10" CornerRadius="3" Background="#10B981" Margin="0,0,6,0"/>
                            <TextBlock Text="Income" FontSize="12" Foreground="#64748B" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <Border Width="10" Height="10" CornerRadius="3" Background="#EF4444" Margin="0,0,6,0"/>
                            <TextBlock Text="Expenses" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Background Gridlines -->
                    <Grid Grid.Row="1" Height="160" VerticalAlignment="Bottom">
                        <StackPanel VerticalAlignment="Stretch" Margin="0,0,0,24">
                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Height="28"/>
                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Height="28"/>
                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Height="28"/>
                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Height="28"/>
                        </StackPanel>
                    </Grid>

                    <!-- Smooth Line Chart (real data) -->
                    <Grid Grid.Row="1" Height="160" VerticalAlignment="Bottom">
                        <!-- Horizontal months labels at the bottom -->
                        <Grid VerticalAlignment="Bottom" Height="24" Panel.ZIndex="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Label0" Grid.Column="0" Text="-" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="Label1" Grid.Column="1" Text="-" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="Label2" Grid.Column="2" Text="-" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="Label3" Grid.Column="3" Text="-" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="Label4" Grid.Column="4" Text="-" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="Label5" Grid.Column="5" Text="-" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Canvas for Lines & Splines -->
                        <Canvas x:Name="ChartCanvas" Height="136" VerticalAlignment="Top" Margin="0,0,0,24" Background="Transparent">
                            <!-- Income path spline -->
                            <Path x:Name="IncomePath" Stroke="#10B981" StrokeThickness="3.5">
                                <Path.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Color="#10B981" Opacity="0.2"/>
                                </Path.Effect>
                            </Path>

                            <!-- Expenses path spline -->
                            <Path x:Name="ExpensePath" Stroke="#EF4444" StrokeThickness="3.5">
                                <Path.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Color="#EF4444" Opacity="0.2"/>
                                </Path.Effect>
                            </Path>
                        </Canvas>
                    </Grid>

                    <!-- Empty State Illustration (shown when no data) -->
                    <Border x:Name="ChartEmptyState" Grid.Row="1" Background="White" CornerRadius="8" Visibility="Visible">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                            <!-- Hand-drawn style chart illustration using WPF Paths -->
                            <Canvas Width="240" Height="110" Margin="0,0,0,10">
                                <!-- Ground line -->
                                <Line X1="10" Y1="95" X2="230" Y2="95" Stroke="#E2E8F0" StrokeThickness="2"/>

                                <!-- Y-axis guide lines (dashed) -->
                                <Line X1="10" Y1="70" X2="230" Y2="70" Stroke="#F1F5F9" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <Line X1="10" Y1="45" X2="230" Y2="45" Stroke="#F1F5F9" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <Line X1="10" Y1="20" X2="230" Y2="20" Stroke="#F1F5F9" StrokeThickness="1" StrokeDashArray="4,4"/>

                                <!-- Ghost bars — muted, illustrative -->
                                <Rectangle Canvas.Left="18" Canvas.Top="65" Width="12" Height="30" Fill="#EEF0F3" RadiusX="3" RadiusY="3"/>
                                <Rectangle Canvas.Left="34" Canvas.Top="75" Width="12" Height="20" Fill="#F8D7DA" RadiusX="3" RadiusY="3"/>

                                <Rectangle Canvas.Left="58" Canvas.Top="50" Width="12" Height="45" Fill="#EEF0F3" RadiusX="3" RadiusY="3"/>
                                <Rectangle Canvas.Left="74" Canvas.Top="65" Width="12" Height="30" Fill="#F8D7DA" RadiusX="3" RadiusY="3"/>

                                <Rectangle Canvas.Left="98" Canvas.Top="30" Width="12" Height="65" Fill="#D1E7DD" RadiusX="3" RadiusY="3"/>
                                <Rectangle Canvas.Left="114" Canvas.Top="50" Width="12" Height="45" Fill="#F8D7DA" RadiusX="3" RadiusY="3"/>

                                <Rectangle Canvas.Left="138" Canvas.Top="55" Width="12" Height="40" Fill="#EEF0F3" RadiusX="3" RadiusY="3"/>
                                <Rectangle Canvas.Left="154" Canvas.Top="60" Width="12" Height="35" Fill="#F8D7DA" RadiusX="3" RadiusY="3"/>

                                <Rectangle Canvas.Left="178" Canvas.Top="40" Width="12" Height="55" Fill="#EEF0F3" RadiusX="3" RadiusY="3"/>
                                <Rectangle Canvas.Left="194" Canvas.Top="45" Width="12" Height="50" Fill="#F8D7DA" RadiusX="3" RadiusY="3"/>

                                <!-- Highlighted tallest bar (accent orange/green) -->
                                <Rectangle Canvas.Left="98" Canvas.Top="30" Width="12" Height="65" Stroke="#10B981" StrokeThickness="1.5" Fill="Transparent" RadiusX="3" RadiusY="3"/>

                                <!-- Sparkle dots on top of bars -->
                                <Ellipse Canvas.Left="21" Canvas.Top="61" Width="6" Height="6" Fill="#94A3B8"/>
                                <Ellipse Canvas.Left="61" Canvas.Top="46" Width="6" Height="6" Fill="#94A3B8"/>
                                <Ellipse Canvas.Left="101" Canvas.Top="26" Width="6" Height="6" Fill="#10B981"/>
                                <Ellipse Canvas.Left="141" Canvas.Top="51" Width="6" Height="6" Fill="#94A3B8"/>
                                <Ellipse Canvas.Left="181" Canvas.Top="36" Width="6" Height="6" Fill="#94A3B8"/>
                            </Canvas>

                            <!-- Caption -->
                            <TextBlock Text="No cash flow data yet" FontSize="14" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Center"/>
                            <TextBlock Text="Load demo data or add your first transaction" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>


            <!-- Right Side Widgets (AI Assistant & Birthdays) -->
            <StackPanel Grid.Column="2">
                <!-- AI Assistant Widget Card (matches mockup) -->
                <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E1D6" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.03"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="AI Assistant — today" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                        
                        <!-- Centered Assistant Alert Text -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="3 items flagged for your review before the payroll run." 
                                       TextWrapping="Wrap" FontSize="13" Foreground="#1E293B" Margin="0,0,0,16"/>
                            
                            <Border Background="#FAF6EE" CornerRadius="8" Padding="16" BorderBrush="#E5E1D6" BorderThickness="1">
                                <TextBlock Text="Two staff timesheets look incomplete for the Jul run." 
                                           TextWrapping="Wrap" FontSize="12" Foreground="#64748B"/>
                            </Border>
                        </StackPanel>
                        
                        <!-- Quick Actions -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Later" Click="Later_Click" Background="Transparent" Foreground="#64748B" BorderThickness="0" Margin="0,0,12,0"/>
                            <Button Content="Review" Click="Review_Click" Background="#1E293B" Foreground="#FF7A00" BorderThickness="0" Padding="16,8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Customer Birthdays Widget Card -->
                <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E1D6" BorderThickness="1" Margin="0,20,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="1.5" Direction="270" Color="#000000" Opacity="0.03"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🎂 Customer Birthdays" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,14"/>
                        
                        <!-- Today's Birthdays List -->
                        <TextBlock Text="TODAY" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                        <TextBlock x:Name="NoBirthdaysTodayText" Text="No birthdays today." FontSize="13" Foreground="#94A3B8" Visibility="Visible" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="BirthdaysTodayList" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Send Wishes" Click="SendWishesDashboard_Click" Tag="{Binding}" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,3" FontSize="11" Cursor="Hand"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="#F1F5F9" Margin="0,0,0,12"/>
                        
                        <!-- Upcoming Birthdays List -->
                        <TextBlock Text="UPCOMING THIS MONTH" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                        <TextBlock x:Name="NoUpcomingBirthdaysText" Text="No upcoming birthdays." FontSize="13" Foreground="#94A3B8" Visibility="Collapsed" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="UpcomingBirthdaysList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#1E293B" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Birthday, StringFormat='\{0:MMM d\}'}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Row 3: Recent Transactions Dynamic ItemsControl List -->
        <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E1D6" BorderThickness="1" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Recent transactions" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="DESCRIPTION" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="CUSTOMER / PAYEE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="DATE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="STATUS" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="AMOUNT" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                </Grid>
                
                <Rectangle Height="1" Fill="#eeeeee" Margin="0,0,0,12"/>
                
                <ItemsControl x:Name="RecentTransactionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Margin="0,8,0,8" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="TransactionRow_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding Description}" Foreground="#1E293B" FontWeight="Medium" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PayeeName}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DateText}" Foreground="#555555" VerticalAlignment="Center"/>
                                    
                                    <Border Grid.Column="3" Background="{Binding StatusBg}" CornerRadius="12" Padding="10,4,10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusFg}" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    
                                    <TextBlock Grid.Column="4" Text="{Binding AmountText}" Foreground="{Binding AmountFg}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#f5f5f5" Margin="0,8,0,8"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</Page>
