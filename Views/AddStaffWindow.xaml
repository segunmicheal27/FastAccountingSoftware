<Window x:Class="FastAccountingSoftware.Views.AddStaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add/Edit Staff Member" Width="420" Height="640" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAF6EE">
    <Border Padding="24" CornerRadius="12" Background="White" Margin="12" BorderBrush="#E5E1D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="WindowTitleText" Grid.Row="0" Text="New Staff Member" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Profile Image Selection Row -->
                    <TextBlock Text="Profile Picture" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="0" Width="60" Height="60" Margin="0,0,16,0">
                            <Border x:Name="ImagePlaceholderBorder" Background="#F1F5F9" CornerRadius="30" BorderBrush="#E2E8F0" BorderThickness="1">
                                <TextBlock Text="👤" FontSize="28" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="ImagePreviewBorder" CornerRadius="30" Visibility="Collapsed">
                                <Border.Background>
                                    <ImageBrush x:Name="ImagePreviewBrush" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </Grid>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button x:Name="ChooseImageBtn" Content="Choose Photo" Click="ChooseImage_Click" Height="32" Padding="12,0" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Cursor="Hand"/>
                            <Button x:Name="RemoveImageBtn" Content="Remove" Click="RemoveImage_Click" Margin="0,4,0,0" Height="20" Background="Transparent" Foreground="#EF4444" BorderThickness="0" FontSize="10" Cursor="Hand" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <!-- Name Field -->
                    <TextBlock Text="Staff Name" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,12" VerticalContentAlignment="Center"/>
                    
                    <!-- Role Field -->
                    <TextBlock Text="Role / Title" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="RoleInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                    <!-- Department Field -->
                    <TextBlock Text="Department" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="DepartmentInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                    <!-- Monthly Pay Field -->
                    <TextBlock Text="Monthly Pay (₦)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="MonthlyPayInput" Text="150000" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                    <!-- Status Field -->
                    <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox x:Name="StatusCombo" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,12" VerticalContentAlignment="Center" SelectedIndex="0">
                        <ComboBoxItem Content="Active"/>
                        <ComboBoxItem Content="On Leave"/>
                    </ComboBox>

                    <!-- System Access Role Field -->
                    <TextBlock Text="System Access Role" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox x:Name="SystemRoleCombo" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,12" VerticalContentAlignment="Center" SelectedIndex="1">
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Staff"/>
                    </ComboBox>

                    <!-- Login Password Field -->
                    <TextBlock Text="Login Password" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="PasswordInput" Text="password" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,12" VerticalContentAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click" Background="Transparent" Foreground="#64748B" BorderThickness="0" Margin="0,0,12,0"/>
                <Button Content="Save Staff" Click="SaveButton_Click" Background="#1E293B" Foreground="#FF7A00" BorderThickness="0" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
