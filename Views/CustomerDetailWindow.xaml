<Window
    x:Class="FastAccountingSoftware.Views.CustomerDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Customer Details"
    Height="620" Width="500"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Border CornerRadius="16" Background="#FAF8F5" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Color="#000000" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1B2A1C" CornerRadius="14,14,0,0" Padding="24,20" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Profile Image or Initials -->
                        <Grid Grid.Column="0" Margin="0,0,16,0" Width="56" Height="56">
                            <!-- Fallback Initials Border -->
                            <Border x:Name="InitialsBorder" Background="#FAF6EE" CornerRadius="28">
                                <TextBlock x:Name="HeaderInitials" Text="?" FontSize="22" FontWeight="Bold" Foreground="#FF7A00" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Actual Image Border -->
                            <Border x:Name="ImageBorder" CornerRadius="28" Visibility="Collapsed">
                                <Border.Background>
                                    <ImageBrush x:Name="HeaderImageBrush" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderName" Text="Customer" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="HeaderEmail" Text="" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="#88FFFFFF" FontSize="14" BorderThickness="0" Cursor="Hand" Padding="4"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>
                    <!-- Status Badge -->
                    <Border x:Name="StatusBadge" CornerRadius="20" Padding="16,6" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <TextBlock x:Name="StatusText" FontSize="13" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Info Cards -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="OUTSTANDING BALANCE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="BalanceText" Text="₦0" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="CUSTOMER SINCE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="SinceText" Text="-" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Last Invoice -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8EB;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FF7A00" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="LAST INVOICE DATE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="LastInvText" Text="-" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Email -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#1B2A1C" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="EMAIL ADDRESS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="EmailDetailText" Text="-" FontSize="14" Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Phone -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#1B2A1C" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="PHONE NUMBER" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="PhoneDetailText" Text="-" FontSize="14" Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Address -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#1B2A1C" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="PHYSICAL ADDRESS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="AddressDetailText" Text="-" FontSize="14" Foreground="#1E293B" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Birthday -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FF7A00" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="CUSTOMER BIRTHDAY" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="BirthdayDetailText" Text="-" FontSize="14" Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,16" BorderBrush="#F1ECE7" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="EditDetailsBtn" Content="Edit Details" Click="Edit_Click"
                                Background="#FF7A00" Foreground="White" Padding="20,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button x:Name="SendWishesBtn" Content="🎂 Send Wishes" Click="SendWishes_Click"
                                Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="20,10" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>
                    <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right"
                            Background="#1B2A1C" Foreground="White" Padding="24,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
