<Page
    x:Class="FastAccountingSoftware.Views.StaffPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Staff" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Manage active staff across departments." Foreground="#555555" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Add staff member" Click="AddStaff_Click" Background="#1E293B" Foreground="#FF7A00" Padding="16,8,16,8"/>
        </Grid>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <Button Content="All departments" Background="#1E293B" Foreground="#FF7A00" />
            </StackPanel>
        </Grid>

        <!-- DataGrid (Mockup list based on design) -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="STAFF MEMBER" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="ROLE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="DEPARTMENT" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="MONTHLY PAY" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="STATUS" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="" />
                </Grid>
                
                <Rectangle Height="1" Fill="#eeeeee" Margin="0,0,0,12"/>
                
                <ItemsControl x:Name="StaffList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Margin="0,8,0,8" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="StaffRow_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Grid Width="36" Height="36" Margin="0,0,12,0">
                                            <!-- Fallback Initials -->
                                            <Border x:Name="InitialsBg" Width="36" Height="36" CornerRadius="18" Background="#1E293B">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Name[0]}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- Actual Profile Image -->
                                            <Border x:Name="PhotoBg" Width="36" Height="36" CornerRadius="18">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ProfilePicturePath, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="#1E293B" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding StaffId, StringFormat='ID: \{0\}'}" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="📋" MouseLeftButtonUp="CopyId_Click" Tag="{Binding StaffId}" Margin="4,0,0,0" Padding="2" Cursor="Hand" ToolTip="Copy ID" FontSize="9" VerticalAlignment="Center" Foreground="#888888"/>
                                                <TextBlock Text=" • " Foreground="#cccccc" FontSize="11" Margin="4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding UsernameText}" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="📋" MouseLeftButtonUp="CopyUsername_Click" Tag="{Binding UsernameTextClean}" Margin="4,0,0,0" Padding="2" Cursor="Hand" ToolTip="Copy Username" FontSize="9" VerticalAlignment="Center" Foreground="#888888"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Department}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding MonthlyPayText}" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    
                                    <Border Grid.Column="4" Background="#eaf4ea" CornerRadius="12" Padding="12,4,12,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="#1E293B" FontSize="12"/>
                                    </Border>
                                    
                                    <TextBlock Grid.Column="5" Text="View →" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#eeeeee" Margin="0,8,0,8"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pagination Bar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="&lt; Prev" Click="Prev_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                    <TextBlock x:Name="PageInfoText" Text="Page 1 of 1"
                               FontSize="13" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Next &gt;" Click="Next_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
