<Window
    x:Class="FastAccountingSoftware.Views.InvoiceDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Invoice Details"
    Height="600" Width="550"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Border CornerRadius="16" Background="#FAF8F5" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Color="#000000" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Band -->
            <Border Grid.Row="0" Background="#1B2A1C" CornerRadius="14,14,0,0" Padding="24,20" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="📄" FontSize="26" Foreground="White"/>
                        <TextBlock x:Name="HeaderInvoiceNumber" Text="Invoice #INV-0000" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                        <TextBlock x:Name="HeaderCustomerName" Text="Customer Name" FontSize="14" Foreground="#94A3B8" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="#88FFFFFF" FontSize="14" BorderThickness="0" Cursor="Hand" Padding="4"/>
                </Grid>
            </Border>

            <!-- Content Area (Scrollable Invoice Sheet) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>
                    <!-- Printable Sheet Area -->
                    <Border x:Name="PrintArea" Background="White" CornerRadius="8" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <!-- Invoice Top Info -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="FAST ACCOUNTING" FontSize="14" FontWeight="Bold" Foreground="#1B2A1C"/>
                                    <TextBlock Text="Lagos, Nigeria" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                    <TextBlock Text="finance@fastaccounting.com" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock x:Name="StatusBadge" Text="PAID" FontSize="12" FontWeight="Bold" Foreground="#2E7D32" 
                                               Background="#E8F5E9" Padding="10,4" HorizontalAlignment="Right" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="InvoiceDateText" Text="Issued: Jan 1, 2026" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="DueDateText" Text="Due: Jan 15, 2026" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#E2E8F0" Margin="0,0,0,20"/>

                            <!-- Bill To Section -->
                            <StackPanel Margin="0,0,0,24">
                                <TextBlock Text="BILL TO" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                <TextBlock x:Name="CustomerNameText" Text="Customer Name" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock x:Name="CustomerEmailText" Text="email@example.com" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                <TextBlock x:Name="CustomerPhoneText" Text="+234 000 000 0000" FontSize="12" Foreground="#64748B"/>
                            </StackPanel>

                            <!-- Items Table -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="DESCRIPTION" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Grid.Column="1" Text="QTY" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="AMOUNT" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#E2E8F0" Margin="0,4,0,12"/>

                            <!-- Item Row 1 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Professional Services" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Accounting services &amp; consultations" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="1" FontSize="13" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ItemAmountText" Grid.Column="2" Text="₦0.00" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Separator Background="#E2E8F0" Margin="0,12,0,16"/>

                            <!-- Total Section -->
                            <Grid HorizontalAlignment="Right" Width="200">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Amount:" FontSize="13" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalAmountText" Grid.Column="1" Text="₦0.00" FontSize="18" FontWeight="Bold" Foreground="#1B2A1C" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Action Buttons -->
            <Border Grid.Row="2" Padding="24,16" BorderBrush="#F1ECE7" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="🖨 Print Invoice" Click="Print_Click"
                                Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="16,10" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button Content="✉ Send via Email" Click="Email_Click"
                                Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="16,10" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>
                    
                    <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right"
                            Background="#1B2A1C" Foreground="White" Padding="24,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
