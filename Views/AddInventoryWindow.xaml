<Window x:Class="FastAccountingSoftware.Views.AddInventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add/Edit Product" Width="400" Height="500" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAF6EE">
    <Border Padding="24" CornerRadius="12" Background="White" Margin="12" BorderBrush="#E5E1D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock x:Name="TitleText" Grid.Row="0" Text="Add New Product" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

            <!-- Inputs -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Product Name -->
                    <TextBlock Text="Product Name" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Quantity -->
                    <TextBlock Text="Quantity in Stock" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="QuantityInput" Text="0" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Cost Price -->
                    <TextBlock Text="Unit Cost Price (₦)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="CostPriceInput" Text="0" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Selling Price -->
                    <TextBlock Text="Selling Price (₦)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="SellingPriceInput" Text="0" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Reorder Level -->
                    <TextBlock Text="Reorder Alert Level" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="ReorderLevelInput" Text="5" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,4" VerticalContentAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click" Background="Transparent" Foreground="#64748B" BorderThickness="0" Margin="0,0,12,0"/>
                <Button Content="Save Product" Click="SaveButton_Click" Background="#1E293B" Foreground="#FF7A00" BorderThickness="0" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
