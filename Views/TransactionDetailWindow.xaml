<Window
    x:Class="FastAccountingSoftware.Views.TransactionDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Transaction Details"
    Height="500" Width="460"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Border CornerRadius="16" Background="#FAF8F5" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Color="#000000" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" x:Name="HeaderBand" CornerRadius="14,14,0,0" Padding="24,20" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="TypeIcon" Text="↑" FontSize="26" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TypeLabel" Text="Income" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                        <TextBlock x:Name="AmountText" Text="₦0" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="#88FFFFFF" FontSize="14" BorderThickness="0" Cursor="Hand" Padding="4"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>
                    <!-- Description -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <TextBlock x:Name="DescText" Text="-" FontSize="14" Foreground="#1E293B" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Date + Type row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="DATE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DateText" Text="-" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="TYPE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TypeDetailText" Text="-" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Dynamic Attributes Header & Container -->
                    <StackPanel x:Name="DynamicAttributesSection" Visibility="Collapsed" Margin="0,16,0,0">
                        <TextBlock Text="CUSTOM SPREADSHEET COLUMNS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <StackPanel x:Name="DynamicAttributesContainer">
                            <!-- Populated dynamically -->
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,16" BorderBrush="#F1ECE7" BorderThickness="0,1,0,0">
                <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right"
                        Background="#1B2A1C" Foreground="White" Padding="24,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
            </Border>
        </Grid>
    </Border>
</Window>
