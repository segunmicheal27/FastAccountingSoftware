<Page
    x:Class="FastAccountingSoftware.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    mc:Ignorable="d"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Admin Profile &amp; Company Settings" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Update your administrator credentials and business details." Foreground="#555555" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Profile Form Card -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Column 1: Admin Account Credentials -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Administrator Account" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>
                    
                    <!-- Username -->
                    <TextBlock Text="Username" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,20">
                        <Grid Margin="18,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBox x:Name="UsernameBox" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <!-- Password -->
                    <TextBlock Text="New Password" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,24">
                        <Grid Margin="18,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBox x:Name="PasswordBox" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Update Credentials" Click="SaveAccount_Click" Background="#1B2A1C" Foreground="White" Margin="0,0,12,0"/>
                        <Button Content="Log Out" Click="Logout_Click" Background="#D9534F" Foreground="White" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Column 2: Company Profile Settings -->
            <Border x:Name="CompanyProfileBorder" Grid.Column="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Company Profile" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>
                    
                    <!-- Company Name -->
                    <TextBlock Text="Company Name" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,20">
                        <Grid Margin="18,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBox x:Name="CompanyNameBox" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <!-- Email -->
                    <TextBlock Text="Business Email" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,20">
                        <Grid Margin="18,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBox x:Name="CompanyEmailBox" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <!-- Address -->
                    <TextBlock Text="Physical Address" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,24">
                        <Grid Margin="18,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE815;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBox x:Name="CompanyAddressBox" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <Button Content="Update Company Profile" Click="SaveCompany_Click" HorizontalAlignment="Left" Background="#FF7A00" Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
