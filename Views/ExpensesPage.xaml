<Page
    x:Class="FastAccountingSoftware.Views.ExpensesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Expenses" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Record and categorize outbound payments." Foreground="#555555" Margin="0,4,0,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📥 Export Data ▼" Click="Export_Click" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="14,8" Cursor="Hand" Margin="0,0,10,0">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Export as Excel (.csv)" Click="ExportExcel_Click"/>
                            <MenuItem Header="Export as Word (.doc)" Click="ExportWord_Click"/>
                            <MenuItem Header="Export as PDF (.pdf)" Click="ExportPdf_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button Content="+ Record Expense" Click="NewExpense_Click" Background="#1E293B" Foreground="#FF7A00" Padding="16,8" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Recent Expenses" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>
                
                <ItemsControl Grid.Row="1" x:Name="TransactionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF" CornerRadius="8" Padding="16" BorderBrush="#FFF8F5" BorderThickness="1" Margin="0,0,0,12" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="TransactionRow_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" /> <!-- 40px circle + 16px exact gap spacing -->
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Centered Icon inside light-red Circle -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#FCEBEA" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE826;" Foreground="#F44336" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="15" />
                                        <TextBlock Text="{Binding DateText}" Foreground="#888888" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding AmountText, StringFormat='- \{0\}'}" FontWeight="Bold" Foreground="#C62828" FontSize="16" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pagination Bar -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="&lt; Prev" Click="Prev_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                    <TextBlock x:Name="PageInfoText" Text="Page 1 of 1"
                               FontSize="13" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Next &gt;" Click="Next_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
