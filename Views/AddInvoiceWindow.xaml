<Window x:Class="FastAccountingSoftware.Views.AddInvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Invoice" Width="400" Height="540" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAF6EE">
    <Border Padding="24" CornerRadius="12" Background="White" Margin="12" BorderBrush="#E5E1D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="New Invoice" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
            
            <StackPanel Grid.Row="1">
                <!-- Customer Selection -->
                <TextBlock Text="Customer" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                <ComboBox x:Name="CustomerSelector" DisplayMemberPath="Name" Height="38" Background="#FAF6F0" Margin="0,0,0,16"/>
                
                <!-- Invoice Number -->
                <TextBlock Text="Invoice Number" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                <TextBox x:Name="InvoiceNumberInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                <!-- Image Attachment & OCR -->
                <TextBlock Text="Invoice Image / Scan" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Height="80" Background="#F1F5F9" CornerRadius="8" BorderBrush="#E5E1D6" BorderThickness="1" ClipToBounds="True">
                        <Image x:Name="InvoiceImage" Stretch="UniformToFill"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Button Content="Attach Photo" Click="ChooseImage_Click" Background="#1E293B" Foreground="White" Height="32" Margin="0,0,0,6" BorderThickness="0" FontSize="11"/>
                        <Button Content="OCR: Read Invoice" Click="OcrExtract_Click" Background="#FF7A00" Foreground="White" Height="32" BorderThickness="0" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Amount -->
                <TextBlock Text="Amount (₦)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                <TextBox x:Name="AmountInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>
            </StackPanel>
            
            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click" Background="Transparent" Foreground="#64748B" BorderThickness="0" Margin="0,0,12,0"/>
                <Button Content="Create Invoice" Click="SaveButton_Click" Background="#1E293B" Foreground="#FF7A00" BorderThickness="0" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
