<Page
    x:Class="FastAccountingSoftware.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    mc:Ignorable="d"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Settings &amp; Preferences" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Manage HMO providers, load/wipe demo data, and adjust currency and tax configurations." Foreground="#555555" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Multi-Card Grid Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <StackPanel Grid.Column="0">
                
                <!-- Card 1: Data Management -->
                <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Data Management" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                        <TextBlock Text="Populate the system with 1,500+ realistic transaction entries, staff profiles, and active customers, or completely wipe all ledger entries to start fresh." 
                                   TextWrapping="Wrap" Foreground="#555555" FontSize="13" Margin="0,0,0,20" LineHeight="20"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="LoadDemoDataButton" 
                                    Content="Load Demo Data" 
                                    Background="#1E293B" 
                                    Foreground="#FF7A00" 
                                    Click="LoadDemoDataButton_Click"
                                    Margin="0,0,12,0"/>
                            
                            <Button x:Name="DeleteDemoDataButton" 
                                    Content="Delete Demo Data" 
                                    Background="#D9534F" 
                                    Foreground="White" 
                                    Click="DeleteDemoDataButton_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="StatusMessage" Foreground="#2E7D32" FontWeight="SemiBold" Margin="0,12,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: HMO Providers Management -->
                <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="HMO Providers" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="Configure health insurance partners and plans for staff payroll benefits." 
                                   TextWrapping="Wrap" Foreground="#555555" FontSize="13" Margin="0,0,0,16"/>

                        <!-- Add HMO Form -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Provider Name" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="6" Height="38">
                                        <TextBox x:Name="HmoNameBox" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="8,0" FontSize="13"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Plan Level" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="6" Height="38">
                                        <ComboBox x:Name="HmoPlanCombo" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="8,0" FontSize="13">
                                            <ComboBoxItem Content="Bronze" IsSelected="True"/>
                                            <ComboBoxItem Content="Silver"/>
                                            <ComboBoxItem Content="Gold"/>
                                            <ComboBoxItem Content="Platinum"/>
                                        </ComboBox>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Premium (₦)" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="6" Height="38">
                                        <TextBox x:Name="HmoPremiumBox" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="8,0" FontSize="13"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Button Content="Add HMO Provider" Click="AddHmo_Click" Margin="0,12,0,0" HorizontalAlignment="Left" Background="#1B2A1C" Foreground="White"/>
                        </StackPanel>

                        <!-- HMO List -->
                        <StackPanel Grid.Row="3">
                            <TextBlock Text="Active HMO Partners" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                            
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PROVIDER" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Grid.Column="1" Text="PLAN LEVEL" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Grid.Column="2" Text="PREMIUM" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                            </Grid>
                            
                            <Rectangle Height="1" Fill="#eeeeee" Margin="0,0,0,10"/>

                            <ItemsControl x:Name="HmoList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid Margin="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" Foreground="#1E293B" FontWeight="Medium" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding PlanType}" FontSize="13" Foreground="#555555" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding PremiumText}" FontSize="13" Foreground="#1E293B" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Rectangle Height="1" Fill="#f9f9f9" Margin="0,4,0,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="2">
                
                <!-- Card 3: Financial Settings -->
                <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Financial Preferences" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,6"/>
                        <TextBlock Text="Adjust standard tax policies, currency codes, and fiscal calendars." 
                                   TextWrapping="Wrap" Foreground="#555555" FontSize="13" Margin="0,0,0,20"/>

                        <!-- Currency Symbol -->
                        <TextBlock Text="Currency Symbol" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,20">
                            <ComboBox x:Name="CurrencyCombo" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="14,0" FontSize="15" FontWeight="SemiBold">
                                <ComboBoxItem Content="₦ (Nigerian Naira)" IsSelected="True"/>
                                <ComboBoxItem Content="$ (US Dollar)"/>
                                <ComboBoxItem Content="£ (British Pound)"/>
                                <ComboBoxItem Content="€ (Euro)"/>
                            </ComboBox>
                        </Border>

                        <!-- Corporate Tax Rate -->
                        <TextBlock Text="Corporate Income Tax Rate (%)" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,20">
                            <Grid Margin="18,0,14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TaxRateBox" Text="30" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15"/>
                                <TextBlock Grid.Column="1" Text="%" FontSize="15" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Fiscal Year Start -->
                        <TextBlock Text="Fiscal Year Start Month" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,28">
                            <ComboBox x:Name="FiscalStartCombo" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="14,0" FontSize="15">
                                <ComboBoxItem Content="January" IsSelected="True"/>
                                <ComboBoxItem Content="April"/>
                                <ComboBoxItem Content="July"/>
                                <ComboBoxItem Content="October"/>
                            </ComboBox>
                        </Border>

                        <Button Content="Save Financial Settings" Click="SavePreferences_Click" Background="#FF7A00" Foreground="White" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Card 4: Birthday Message Template -->
                <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="Birthday Message Template" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,6"/>
                        <TextBlock Text="Customize the default message sent to customers on their birthdays. Use {Name} as placeholder." 
                                   TextWrapping="Wrap" Foreground="#555555" FontSize="13" Margin="0,0,0,16" LineHeight="18"/>
                        
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="90" Margin="0,0,0,16">
                            <TextBox x:Name="BirthdayTemplateBox" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0" Background="Transparent" Padding="12,8" FontSize="13" Foreground="#1E293B" VerticalContentAlignment="Top"/>
                        </Border>
                        
                        <Button Content="Save Template" Click="SaveTemplate_Click" Background="#1B2A1C" Foreground="White" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
