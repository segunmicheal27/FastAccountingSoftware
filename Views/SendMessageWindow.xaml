<Window x:Class="FastAccountingSoftware.Views.SendMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Message" Width="440" Height="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAF6EE">
    <Border Padding="24" CornerRadius="12" Background="White" Margin="12" BorderBrush="#E5E1D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="✉ Send Message" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock x:Name="RecipientText" Text="To: -" FontSize="13" Foreground="#64748B" Margin="0,4,0,0" FontWeight="SemiBold"/>
            </StackPanel>
            
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Message Body" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox x:Name="MessageInput" Grid.Row="1" 
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Padding="12" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" 
                         FontSize="14" Foreground="#1E293B" AcceptsTab="True"/>
            </Grid>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click" Background="Transparent" Foreground="#64748B" BorderThickness="0" Margin="0,0,12,0" Padding="16,8" Cursor="Hand"/>
                <Button Content="Send Message" Click="Send_Click" Background="#1B2A1C" Foreground="White" BorderThickness="0" Padding="20,10" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
