<Window x:Class="FastAccountingSoftware.Views.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add/Edit Customer" Width="420" Height="620" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAF6EE">
    <Border Padding="24" CornerRadius="12" Background="White" Margin="12" BorderBrush="#E5E1D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#000000" Opacity="0.05"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="WindowTitleText" Grid.Row="0" Text="New Customer" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Profile Image Selection Row -->
                    <TextBlock Text="Profile Picture" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid Grid.Column="0" Width="60" Height="60" Margin="0,0,16,0">
                            <Border x:Name="ImagePlaceholderBorder" Background="#F1F5F9" CornerRadius="30" BorderBrush="#E2E8F0" BorderThickness="1">
                                <TextBlock Text="👤" FontSize="28" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="ImagePreviewBorder" CornerRadius="30" Visibility="Collapsed">
                                <Border.Background>
                                    <ImageBrush x:Name="ImagePreviewBrush" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </Grid>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button x:Name="ChooseImageBtn" Content="Choose Photo" Click="ChooseImage_Click" Height="32" Padding="12,0" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Cursor="Hand"/>
                            <Button x:Name="RemoveImageBtn" Content="Remove" Click="RemoveImage_Click" Margin="0,4,0,0" Height="20" Background="Transparent" Foreground="#EF4444" BorderThickness="0" FontSize="10" Cursor="Hand" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <!-- Name Field -->
                    <TextBlock Text="Customer Name" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>
                    
                    <!-- Email Field -->
                    <TextBlock Text="Email Address" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="EmailInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Balance Field -->
                    <TextBlock Text="Initial Balance (₦)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="BalanceInput" Text="0" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Phone Field -->
                    <TextBlock Text="Phone Number" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="PhoneInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Address Field -->
                    <TextBlock Text="Physical Address" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="AddressInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Birthday Field -->
                    <TextBlock Text="Customer Birthday" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <DatePicker x:Name="BirthdayInput" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <!-- Status Field -->
                    <TextBlock Text="Account Status" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox x:Name="StatusCombo" Height="38" Background="#FAF6F0" BorderBrush="#E5E1D6" BorderThickness="1" Padding="8,2" Margin="0,0,0,4" VerticalContentAlignment="Center" SelectedIndex="0">
                        <ComboBoxItem Content="Current"/>
                        <ComboBoxItem Content="Pending"/>
                        <ComboBoxItem Content="Overdue"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click" Background="Transparent" Foreground="#64748B" BorderThickness="0" Margin="0,0,12,0"/>
                <Button Content="Save Customer" Click="SaveButton_Click" Background="#1E293B" Foreground="#FF7A00" BorderThickness="0" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
