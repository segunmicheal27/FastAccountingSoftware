<Window
    x:Class="FastAccountingSoftware.Views.ReportViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Financial Report Viewer"
    Height="780" Width="780"
    MinHeight="600" MinWidth="650"
    WindowStartupLocation="CenterOwner"
    Background="#F5F5F0"
    BorderThickness="0"
    FontFamily="Segoe UI Variable, Segoe UI, Sans-Serif"
    WindowStyle="None"
    AllowsTransparency="False">

    <Window.Resources>
        <Style x:Key="ExportBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Brand header -->
            <RowDefinition Height="Auto"/>  <!-- Report title bar -->
            <RowDefinition Height="*"/>     <!-- Report body -->
            <RowDefinition Height="Auto"/>  <!-- Footer / export bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════
             ROW 0 — Brand Header (logo + company name)
             ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1B2A1C" Padding="28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/fas-without-text.png" Width="36" Height="36"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Fast" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF7A00"/>
                        <TextBlock Text="AccountingSoftware" FontSize="10"
                                   Foreground="#88FFFFFF" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Company name from profile -->
                <TextBlock Grid.Column="1" x:Name="CompanyNameText"
                           Text="" FontSize="13" Foreground="#AAFFFFFF"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Window drag + close -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="✕" Click="Close_Click"
                            Background="Transparent" Foreground="#88FFFFFF"
                            BorderThickness="0" FontSize="16" Cursor="Hand"
                            Padding="8,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             ROW 1 — Report Title Bar (orange accent)
             ══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#FF7A00" Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="ReportTitleText"
                               Text="PROFIT &amp; LOSS STATEMENT"
                               FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="ReportPeriodText"
                               Text="For the period ending today"
                               FontSize="12" Foreground="#DDFFFFFF" Margin="0,3,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1B2A1C" CornerRadius="6"
                        Padding="12,6" VerticalAlignment="Center">
                    <TextBlock x:Name="GeneratedDateText"
                               FontSize="11" Foreground="#FF7A00"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             ROW 2 — Scrollable Report Body
             ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Background="#FAF8F4">
            <StackPanel x:Name="ReportContentArea" Margin="36,28,36,28"/>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════════
             ROW 3 — Export / Action Footer
             ══════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#E5E1D6" BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Export buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Export as:" FontSize="12" Foreground="#888888"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <Button x:Name="ExportPdfBtn" Content="📄  PDF"
                            Style="{StaticResource ExportBtn}"
                            Background="#FFF0E8" Foreground="#CC4400"
                            Click="ExportPdf_Click" Margin="0,0,8,0"
                            ToolTip="Export report as PDF"/>

                    <Button x:Name="ExportExcelBtn" Content="📊  Excel (CSV)"
                            Style="{StaticResource ExportBtn}"
                            Background="#E8F5E9" Foreground="#2E7D32"
                            Click="ExportExcel_Click" Margin="0,0,8,0"
                            ToolTip="Export report as CSV — opens in Microsoft Excel"/>

                    <Button x:Name="ExportWordBtn" Content="📝  Word (RTF)"
                            Style="{StaticResource ExportBtn}"
                            Background="#E3F2FD" Foreground="#1565C0"
                            Click="ExportWord_Click" Margin="0,0,8,0"
                            ToolTip="Export report as RTF — opens in Microsoft Word"/>

                    <Button x:Name="SendEmailBtn" Content="✉️  Send Email"
                            Style="{StaticResource ExportBtn}"
                            Background="#ECEFF1" Foreground="#37474F"
                            Click="SendEmail_Click" Margin="0,0,0,0"
                            ToolTip="Send this report via Email"/>
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="1" Content="Close"
                        Click="Close_Click"
                        Background="#1B2A1C" Foreground="White"
                        BorderThickness="0" Padding="28,10"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
