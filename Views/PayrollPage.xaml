<Page
    x:Class="FastAccountingSoftware.Views.PayrollPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Payroll" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock x:Name="HeaderSubtitleText" Text="Manage monthly employee payouts and tax filings." Foreground="#555555" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="✓ Run payroll" Click="RunPayroll_Click" Background="#1E293B" Foreground="#FF7A00" Padding="16,8,16,8"/>
        </Grid>

        <!-- Summary Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="GROSS PAYROLL" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="GrossPayrollValueText" Text="₦0" FontSize="36" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,8"/>
                    <TextBlock x:Name="StaffCount1Text" Text="0 staff active" Foreground="#555555"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="STATUTORY DEDUCTIONS (15%)" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DeductionsValueText" Text="₦0" FontSize="36" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,8"/>
                    <TextBlock Text="PAYE, Pension, NHF" Foreground="#555555"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="NET PAYABLE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="NetPayableValueText" Text="₦0" FontSize="36" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,8"/>
                    <TextBlock Text="On active cycle" Foreground="#555555"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- History -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Payroll history" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="RUN" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="STAFF PAID" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="DATE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="STATUS" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="TOTAL" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                </Grid>
                
                <Rectangle Height="1" Fill="#eeeeee" Margin="0,0,0,12"/>
                
                <ItemsControl x:Name="PayrollHistoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Margin="0,8,0,8" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="PayrollRow_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding StaffPaidCount}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DateText}" Foreground="#555555" VerticalAlignment="Center"/>
                                    
                                    <Border Grid.Column="3" Background="#eaf4ea" CornerRadius="12" Padding="12,4,12,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="#1E293B" FontSize="12"/>
                                    </Border>
                                    
                                    <TextBlock Grid.Column="4" Text="{Binding TotalAmountText}" Foreground="#1E293B" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#eeeeee" Margin="0,8,0,8"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pagination Bar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="&lt; Prev" Click="Prev_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                    <TextBlock x:Name="PageInfoText" Text="Page 1 of 1"
                               FontSize="13" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Next &gt;" Click="Next_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
