<Page
    x:Class="FastAccountingSoftware.Views.InvoicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Invoices" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Outstanding company invoices and billing records." Foreground="#555555" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📥 Export Data ▼" Click="Export_Click" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="14,8" Cursor="Hand" Margin="0,0,10,0">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Export as Excel (.csv)" Click="ExportExcel_Click"/>
                            <MenuItem Header="Export as Word (.doc)" Click="ExportWord_Click"/>
                            <MenuItem Header="Export as PDF (.pdf)" Click="ExportPdf_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button Content="📥 Import Excel" Click="ImportExcel_Click" Background="#FF7A00" Foreground="White" Padding="14,8" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="+ New invoice" Click="NewInvoice_Click" Background="#1E293B" Foreground="#FF7A00" Padding="16,8" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid (Mockup list based on design) -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1" VerticalAlignment="Top">
            <StackPanel>
                <!-- Bulk Actions Panel -->
                <Border x:Name="BulkActionsPanel" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Bulk Actions:" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="✉ Email Selected Invoices" Click="BulkEmailInvoices_Click" Background="#1B2A1C" Foreground="White" Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" x:Name="SelectAllInvoices" Click="SelectAllInvoices_Click" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="INVOICE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="CUSTOMER" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="ISSUED" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="DUE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="STATUS" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="AMOUNT" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                
                <Rectangle Height="1" Fill="#eeeeee" Margin="0,0,0,12"/>
                
                <ItemsControl x:Name="InvoicesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Margin="0,8,0,8" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="InvoiceRow_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,12,0" VerticalAlignment="Center" Click="InvoiceCheckbox_Click"/>
                                    <TextBlock Grid.Column="1" Text="{Binding InvoiceNumber}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CustomerName}" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding IssuedDate}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding DueDate}" Foreground="#555555" VerticalAlignment="Center"/>
                                    
                                    <Border Grid.Column="5" Background="#EAF4EA" CornerRadius="12" Padding="12,4,12,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="#1E293B" FontSize="12"/>
                                    </Border>
                                    
                                    <TextBlock Grid.Column="6" Text="{Binding AmountText}" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#eeeeee" Margin="0,8,0,8"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pagination Bar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="&lt; Prev" Click="Prev_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0" Cursor="Hand"/>
                    <TextBlock x:Name="PageInfoText" Text="Page 1 of 1"
                               FontSize="13" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Next &gt;" Click="Next_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
