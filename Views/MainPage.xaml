<Page
    x:Class="FastAccountingSoftware.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="#FAF6EE">

    <Page.Resources>
        <!-- Premium Navigation Button Style - Compact margins -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="NavGroup" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E6FFFFFF" /> <!-- High opacity white for inactive -->
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Margin" Value="16,2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20FFFFFF" /> <!-- Hover effect -->
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF" /> <!-- Solid white for selected -->
                                <Setter Property="Foreground" Value="#E53935" /> <!-- Vibrant red text on white background -->
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1.5" Color="#000000" Opacity="0.12"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Section Header Style - Compact spacing -->
        <Style x:Key="NavHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Opacity" Value="0.65" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="36,16,16,4" /> <!-- Aligned perfectly with menu button icons -->
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Background: Vivid Red to Vibrant Orange Gradient -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                    <GradientStop Color="#E53935" Offset="0.0"/>
                    <GradientStop Color="#FF6D00" Offset="0.6"/>
                    <GradientStop Color="#FF8F00" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Sidebar Grid -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header with high-quality cropped FAS Logo inside a white circle -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="36,24,24,16"> <!-- Aligned perfectly to 36px vertical guide -->
                <Border Width="36" Height="36" CornerRadius="18" Background="White" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#000000" Opacity="0.1"/>
                    </Border.Effect>
                    <TextBlock x:Name="SidebarCompanyAbbrText" Text="BC" Foreground="#E53935" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="SidebarCompanyText" Text="Books &amp; Co" Foreground="#ffffff" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Navigation Items -->
            <StackPanel Grid.Row="1">
                
                <TextBlock Text="OVERVIEW" Style="{StaticResource NavHeaderStyle}" />
                <RadioButton x:Name="NavDashboard" Style="{StaticResource NavButtonStyle}" Tag="Dashboard" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Dashboard" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>

                <TextBlock Text="MANAGE" Style="{StaticResource NavHeaderStyle}" />
                <RadioButton x:Name="NavIncome" Style="{StaticResource NavButtonStyle}" Tag="Income" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Income" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>
                
                <RadioButton x:Name="NavExpenses" Style="{StaticResource NavButtonStyle}" Tag="Expenses" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE826;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Expenses" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>
                
                <RadioButton x:Name="NavCustomers" Style="{StaticResource NavButtonStyle}" Tag="Customers" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Customers" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>
                
                <RadioButton x:Name="NavStaff" Style="{StaticResource NavButtonStyle}" Tag="Staff" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Staff" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>
                
                <RadioButton x:Name="NavPayroll" Style="{StaticResource NavButtonStyle}" Tag="Payroll" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C0;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Payroll" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>
                
                <RadioButton x:Name="NavInvoices" Style="{StaticResource NavButtonStyle}" Tag="Invoices" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Invoices" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="NavInventory" Style="{StaticResource NavButtonStyle}" Tag="Inventory" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Inventory" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>
                
                <RadioButton x:Name="NavReports" Style="{StaticResource NavButtonStyle}" Tag="Reports" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Reports" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>

                <TextBlock Text="SYSTEM" Style="{StaticResource NavHeaderStyle}" x:Name="NavSystemHeader" />
                <RadioButton x:Name="NavSettings" Style="{StaticResource NavButtonStyle}" Tag="Settings" Checked="NavItem_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Width="24" />
                        <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <!-- Footer: Sleek AI Assistant button and user details with initials avatar -->
            <StackPanel Grid.Row="2">
                <Button Content="Ask AI Assistant" 
                        Click="AskAI_Click"
                        Background="#FFFFFF" 
                        Foreground="#E53935" 
                        FontWeight="Bold"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch" 
                        Margin="16,0,16,16"
                        Height="40"
                        md:ButtonAssist.CornerRadius="8"
                        Cursor="Hand">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#000000" Opacity="0.12"/>
                    </Button.Effect>
                </Button>
                
                <StackPanel Orientation="Horizontal" Margin="36,0,16,16" MouseLeftButtonDown="Profile_Tapped" Cursor="Hand" Background="Transparent"> <!-- Aligned perfectly to 36px vertical guide -->
                    <Border Width="36" Height="36" CornerRadius="18" Background="#33FFFFFF" Margin="0,0,12,0" BorderBrush="#80FFFFFF" BorderThickness="1">
                        <TextBlock x:Name="UserInitialsText" Text="T" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="UserNameText" Text="User Name" Foreground="#ffffff" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock x:Name="UserRoleText" Text="Role" Foreground="#FFFFFF" FontSize="12" Opacity="0.75" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Main Content Area Grid -->
        <Grid Grid.Column="1" Background="#FAF6EE">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" /> <!-- Top Bar -->
                <RowDefinition Height="*" />  <!-- Sub Page Content Frame -->
            </Grid.RowDefinitions>

            <!-- Premium White Top Bar Row matching sample mockup -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E1D6" BorderThickness="0,0,0,1" Padding="36,0,36,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Breadcrumbs (e.g. Books & Co / Dashboard) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="CompanyBreadcrumbText" Text="Books &amp; Co" FontSize="14" Foreground="#64748B" FontWeight="Medium" />
                        <TextBlock Text=" / " FontSize="14" Foreground="#94A3B8" />
                        <TextBlock x:Name="CurrentPageTitleText" Text="Dashboard" FontSize="14" Foreground="#1E293B" FontWeight="Bold" />
                    </StackPanel>

                    <!-- Search Box (mockup style) -->
                    <Border Grid.Column="2" Background="#FAF6F0" CornerRadius="20" Width="380" Height="40" Padding="16,0,16,0" VerticalAlignment="Center" BorderBrush="#E5E1D6" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Search Icon (magnifying glass) -->
                            <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <!-- Search Textbox -->
                            <TextBox Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                     FontSize="13" Foreground="#1E293B" CaretBrush="#1E293B"
                                     md:HintAssist.Hint="Search customers, invoices, staff..." md:TextFieldAssist.DecorationVisibility="Collapsed" />
                        </Grid>
                    </Border>

                    <!-- User Actions Row (Bell, Help, Green Avatar) -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Bell Icon -->
                        <Button Click="Notifications_Click" Background="Transparent" BorderThickness="0" Width="36" Height="36" Padding="0" Margin="0,0,8,0" Cursor="Hand" Style="{StaticResource MaterialDesignFlatButton}">
                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <!-- Help Icon -->
                        <Button Click="Help_Click" Background="Transparent" BorderThickness="0" Width="36" Height="36" Padding="0" Margin="0,0,16,0" Cursor="Hand" Style="{StaticResource MaterialDesignFlatButton}">
                            <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <!-- Dark Green initials Avatar (matches "TA" in mockup) -->
                        <Border Width="36" Height="36" CornerRadius="18" Background="#1E4D2B" Cursor="Hand" MouseLeftButtonDown="ProfileAvatar_Tapped">
                            <TextBlock x:Name="TopBarInitialsText" Text="TA" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content ScrollViewer and Frame -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Padding="36,32,36,36">
                    <Frame x:Name="ContentFrame" Background="Transparent" NavigationUIVisibility="Hidden" />
                </Border>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
