<Page
    x:Class="FastAccountingSoftware.Views.CustomersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Customers" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Manage company accounts, balances and invoice history." Foreground="#555555" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📥 Export Data ▼" Click="Export_Click" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="14,8" Cursor="Hand" Margin="0,0,10,0">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Export as Excel (.csv)" Click="ExportExcel_Click"/>
                            <MenuItem Header="Export as Word (.doc)" Click="ExportWord_Click"/>
                            <MenuItem Header="Export as PDF (.pdf)" Click="ExportPdf_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button Content="+ Add customer" Click="AddCustomer_Click" Background="#1E293B" Foreground="#FF7A00" Padding="16,8" Cursor="Hand"/>
            </StackPanel>
        </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,24">
                <Button x:Name="FilterAllBtn" Content="All accounts" Click="FilterAll_Click" Margin="0,0,8,0" Background="#1E293B" Foreground="#FF7A00" Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="FilterCurrentBtn" Content="Current" Click="FilterCurrent_Click" Margin="0,0,8,0" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="12,6" Cursor="Hand"/>
                <Button x:Name="FilterPendingBtn" Content="Pending" Click="FilterPending_Click" Margin="0,0,8,0" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="12,6" Cursor="Hand"/>
                <Button x:Name="FilterOverdueBtn" Content="Overdue" Click="FilterOverdue_Click" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Padding="12,6" Cursor="Hand"/>
            </StackPanel>

        <!-- DataGrid (Mockup list based on design) -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#e6e1d6" BorderThickness="1">
            <StackPanel>
                <!-- Bulk Actions Panel -->
                <Border x:Name="BulkActionsPanel" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Bulk Actions:" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="🎂 Send Birthday Wishes" Click="BulkSendWishes_Click" Background="#1B2A1C" Foreground="White" Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" x:Name="SelectAllCustomers" Click="SelectAllCustomers_Click" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="CUSTOMER" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="CONTACT" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="BALANCE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="LAST INVOICE" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="STATUS" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="" VerticalAlignment="Center"/>
                </Grid>
                
                <Rectangle Height="1" Fill="#eeeeee" Margin="0,0,0,12"/>
                
                <ItemsControl x:Name="CustomersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Margin="0,8,0,8" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="CustomerRow_Click">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,12,0" VerticalAlignment="Center" Click="CustomerCheckbox_Click"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Grid Width="36" Height="36" Margin="0,0,12,0">
                                            <!-- Fallback Initials -->
                                            <Border x:Name="InitialsBg" Width="36" Height="36" CornerRadius="18" Background="#1E293B">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Name[0]}" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- Actual Profile Image -->
                                            <Border x:Name="PhotoBg" Width="36" Height="36" CornerRadius="18">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ProfilePicturePath, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="#1E293B" FontWeight="SemiBold"/>
                                            <TextBlock Text="Active Account" Foreground="#888888" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding Email}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding BalanceText}" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding LastInvoiceDateText}" Foreground="#555555" VerticalAlignment="Center"/>
                                    
                                    <Border Grid.Column="5" Background="#EAF4EA" CornerRadius="12" Padding="12,4,12,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="#1E293B" FontSize="12"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="✉ Msg" Click="QuickMessage_Click" Tag="{Binding}" FontSize="11" Padding="6,3" Margin="0,0,4,0" Background="#FAF6F0" Foreground="#1E293B" BorderBrush="#E5E1D6" BorderThickness="1" Cursor="Hand"/>
                                        <Button Content="🗑 Del" Click="QuickDelete_Click" Tag="{Binding}" FontSize="11" Padding="6,3" Margin="0,0,4,0" Background="#FFF5F5" Foreground="#C92A2A" BorderBrush="#FFC9C9" BorderThickness="1" Cursor="Hand"/>
                                        <TextBlock Text="Open →" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <Rectangle Height="1" Fill="#eeeeee" Margin="0,8,0,8"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pagination Bar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="&lt; Prev" Click="Prev_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                    <TextBlock x:Name="PageInfoText" Text="Page 1 of 1"
                               FontSize="13" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Next &gt;" Click="Next_Click"
                            Background="#1B2A1C" Foreground="White" Padding="10,6"
                            FontSize="12" Margin="4,0" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
