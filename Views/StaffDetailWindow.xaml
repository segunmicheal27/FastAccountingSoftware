<Window
    x:Class="FastAccountingSoftware.Views.StaffDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Staff Details"
    Height="560" Width="500"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Border CornerRadius="16" Background="#FAF8F5" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Color="#000000" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1B2A1C" CornerRadius="14,14,0,0" Padding="24,20" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Profile Image or Initials -->
                        <Grid Grid.Column="0" Margin="0,0,16,0" Width="56" Height="56">
                            <!-- Fallback Initials Border -->
                            <Border x:Name="InitialsBorder" Background="#FAF6EE" CornerRadius="28">
                                <TextBlock x:Name="HeaderInitials" Text="?" FontSize="22" FontWeight="Bold" Foreground="#FF7A00" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Actual Image Border -->
                            <Border x:Name="ImageBorder" CornerRadius="28" Visibility="Collapsed">
                                <Border.Background>
                                    <ImageBrush x:Name="HeaderImageBrush" Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderName" Text="Staff Member" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="HeaderRole" Text="" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="#88FFFFFF" FontSize="14" BorderThickness="0" Cursor="Hand" Padding="4"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>
                    <!-- Status Badge -->
                    <Border x:Name="StatusBadge" CornerRadius="20" Padding="16,6" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <TextBlock x:Name="StatusText" FontSize="13" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Pay + Department Row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="MONTHLY PAY" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="PayText" Text="₦0" FontSize="20" FontWeight="Bold" Foreground="#1B2A1C"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="DEPARTMENT" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DeptText" Text="-" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Staff ID -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FF7A00" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="STAFF ID" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="StaffIdText" Text="-" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Login Credentials -->
                    <Border Background="#F0F4FF" CornerRadius="10" Padding="16" BorderBrush="#C7D7FF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="LOGIN CREDENTIALS" FontSize="10" FontWeight="Bold" Foreground="#3B5BDB" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" FontSize="13" Foreground="#555" Margin="0,0,12,6"/>
                                <TextBlock x:Name="LoginUser" Grid.Row="0" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" FontSize="13" Foreground="#555" Margin="0,0,12,6"/>
                                <TextBlock x:Name="LoginPassword" Grid.Row="1" Grid.Column="1" Text="password" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="System Role:" FontSize="13" Foreground="#555" Margin="0,0,12,0"/>
                                <TextBlock x:Name="LoginRole" Grid.Row="2" Grid.Column="1" Text="Staff" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,16" BorderBrush="#F1ECE7" BorderThickness="0,1,0,0">
                <Grid>
                    <Button Content="Edit Details" Click="Edit_Click" HorizontalAlignment="Left"
                            Background="#FF7A00" Foreground="White" Padding="20,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                    <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right"
                            Background="#1B2A1C" Foreground="White" Padding="24,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
