<Page
    x:Class="FastAccountingSoftware.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <!-- Gradient Background System matching specs -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF8F4" Offset="0"/>
                <GradientStop Color="White" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Main Window Columns: left flexible, right 520px fixed -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="520"/>
        </Grid.ColumnDefinitions>

        <!-- Background grid overlay -->
        <Grid Grid.ColumnSpan="2" Panel.ZIndex="0">
            <!-- Technical Grid Pattern -->
            <Border Opacity="0.3">
                <Border.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="0,0" EndPoint="40,0" />
                                        <LineGeometry StartPoint="0,0" EndPoint="0,40" />
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#FFEADF" Thickness="1" />
                                </GeometryDrawing.Pen>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Border.Background>
            </Border>

            <!-- Wave Canvas populated dynamically from code-behind (Taller Guilloche mesh, height=320) -->
            <Viewbox Stretch="Fill" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Height="320">
                <Canvas x:Name="WaveCanvas" Width="1366" Height="320" />
            </Viewbox>
        </Grid>

        <!-- LEFT COLUMN: Content & Illustration -->
        <Grid Grid.Column="0" Margin="80,75,40,0" VerticalAlignment="Top" Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo & Company Name (Cropped, aligned next to text, font size 20) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,32" VerticalAlignment="Center">
                <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,14,0" VerticalAlignment="Center">
                    <Border.Background>
                        <ImageBrush ImageSource="pack://application:,,,/Assets/fas-without-text.png" 
                                    Stretch="UniformToFill" 
                                    Viewbox="0.32,0.32,0.36,0.36" />
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="3" Direction="270" Color="#F53A37" Opacity="0.2"/>
                    </Border.Effect>
                </Border>
                
                <TextBlock FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                    <Run Text="Fast" Foreground="#F53A37"/>
                    <Run Text="Accounting" Foreground="#FF7A00"/>
                    <Run Text="Software" Foreground="#20252D"/>
                </TextBlock>
            </StackPanel>

            <!-- Large Heading (Size 44, Bold) & Orange Gradient Divider -->
            <StackPanel Grid.Row="1" Margin="0,0,0,36">
                <TextBlock FontSize="44" FontWeight="Bold" Foreground="#1B2230" LineHeight="54">
                    Smart Accounting.<LineBreak/>Faster Business.
                </TextBlock>
                
                <!-- Orange Gradient Divider (Width 90, Height 4, CornerRadius 2) -->
                <Border Width="90" Height="4" CornerRadius="2" Background="#FF6F00" HorizontalAlignment="Left" Margin="0,16,0,24"/>
                
                <TextBlock Text="A unified accounting system that consolidates financial data, streamlines workflows, and delivers real-time insights across every transaction." 
                           TextWrapping="Wrap" FontSize="16" Foreground="#555555" LineHeight="26" MaxWidth="520" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Features & Illustration Row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Features list using reusable stack panels -->
                <StackPanel VerticalAlignment="Top" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Grid Width="40" Height="40" Margin="0,0,16,0">
                            <Ellipse Fill="#FFF2EB" />
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="#F53A37" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Smart automation for routine tasks" FontSize="14" Foreground="#475569" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="180"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Grid Width="40" Height="40" Margin="0,0,16,0">
                            <Ellipse Fill="#FFF2EB" />
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" Foreground="#F53A37" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Unified financial dashboards" FontSize="14" Foreground="#475569" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="180"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,16,0">
                            <Ellipse Fill="#FFF2EB" />
                            <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" Foreground="#F53A37" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Built for teams of any size" FontSize="14" Foreground="#475569" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="180"/>
                    </StackPanel>
                </StackPanel>

                <!--
                    CUSTOM GENERATED 3D DASHBOARD ILLUSTRATION
                    Loads the premium, custom-rendered 3D Claymorphic & Glassmorphic asset.
                -->
                <Image Grid.Column="1" Source="pack://application:,,,/Assets/dashboard_illustration.png" 
                       Width="300" Height="260" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Direction="270" Color="#F44336" Opacity="0.08"/>
                    </Image.Effect>
                </Image>
            </Grid>
        </Grid>

        <!-- RIGHT COLUMN: Login Form (Using fixed 520px column layout) -->
        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Main Login Card (Set to a comfortable fixed width of 440px with 40px Padding and Shadow) -->
            <Border Width="440" Background="White" CornerRadius="18" Padding="40" BorderBrush="#F2EBE8" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.15"/>
                </Border.Effect>
                
                <!-- Spacing compacted to fit fully on 900px high windows -->
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="Welcome back!" FontSize="28" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                    <TextBlock Text="Please sign in to your account" FontSize="14" Foreground="#888888" HorizontalAlignment="Center" Margin="0,6,0,24"/>
                    
                    <!-- Role Selector (Custom toggle cards) -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Staff Tab -->
                        <Border x:Name="StaffBorder" Grid.Column="0" BorderBrush="#FF6B37" BorderThickness="1.5" Background="#FFF5F0" CornerRadius="8" Padding="14" MouseLeftButtonDown="RoleBorder_Tapped" Tag="Staff" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#F44336" VerticalAlignment="Center"/>
                                    <TextBlock Text="Staff" FontWeight="Bold" Foreground="#1E293B" FontSize="15" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Access staff features" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Admin Tab -->
                        <Border x:Name="AdminBorder" Grid.Column="2" BorderBrush="#FFD6CF" BorderThickness="1" Background="White" CornerRadius="8" Padding="14" MouseLeftButtonDown="RoleBorder_Tapped" Tag="Admin" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#555555" VerticalAlignment="Center"/>
                                    <TextBlock Text="Admin" FontWeight="Bold" Foreground="#1E293B" FontSize="15" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Access admin panel" FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Divider -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1" Fill="#EAEAEA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="OR" FontSize="12" Foreground="#CCCCCC" Margin="18,0,18,0" FontWeight="Bold"/>
                        <Rectangle Grid.Column="2" Height="1" Fill="#EAEAEA" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Email Field (Rounded CornerRadius=8, Height=50, icon left) -->
                    <TextBlock Text="Email" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,20">
                        <Grid Margin="18,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBox x:Name="UsernameBox" md:HintAssist.Hint="Enter your email" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden"/>
                        </Grid>
                    </Border>
                    
                    <!-- Password Field (Rounded CornerRadius=8, Height=50, icon left) -->
                    <TextBlock Text="Password" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="8" Height="50" Margin="0,0,0,18">
                        <Grid Margin="18,0,18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="#94A3B8" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <PasswordBox x:Name="PasswordBox" md:HintAssist.Hint="Enter your password" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden"/>
                            <TextBox x:Name="PasswordTextBox" md:HintAssist.Hint="Enter your password" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Foreground="#1E293B" FontSize="15" md:TextFieldAssist.DecorationVisibility="Hidden" Visibility="Collapsed"/>
                            <TextBlock x:Name="TogglePasswordButton" Grid.Column="2" Text="&#xE890;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="18" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TogglePassword_Click"/>
                        </Grid>
                    </Border>
                    
                    <!-- Remember Me / Forgot Password -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="Remember me" Foreground="#1E293B" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,0">
                            <CheckBox.Resources>
                                <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#F51C38" />
                                <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#F51C38" />
                                <SolidColorBrush x:Key="MaterialDesignSecondaryAccentBrush" Color="#F51C38" />
                            </CheckBox.Resources>
                        </CheckBox>
                        <TextBlock Grid.Column="1" Text="Forgot password?" Foreground="#F44336" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand"/>
                    </Grid>
                    
                    <TextBlock x:Name="ErrorText" Foreground="#D9534F" Visibility="Collapsed" Text="Invalid credentials" Margin="0,0,0,14" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>

                    <!-- Sign In Button (Gradient, Height=50, CornerRadius=8) -->
                    <Button HorizontalAlignment="Stretch" 
                            Height="50" 
                            IsDefault="True"
                            md:ButtonAssist.CornerRadius="8"
                            BorderThickness="0"
                            Click="SignInButton_Click"
                            Margin="0,0,0,20"
                            Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F51C38" Offset="0.0"/>
                                <GradientStop Color="#FF7D00" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <TextBlock Text="Sign In" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    </Button>
                    
                    <!-- Divider -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Height="1" Fill="#EAEAEA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="OR" FontSize="12" Foreground="#CCCCCC" Margin="18,0,18,0" FontWeight="Bold"/>
                        <Rectangle Grid.Column="2" Height="1" Fill="#EAEAEA" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Google Button (White, Border #E8E8E8, Height 50, Radius 8) -->
                    <Button HorizontalAlignment="Stretch" Height="50" md:ButtonAssist.CornerRadius="8" Background="White" BorderBrush="#E8E8E8" BorderThickness="1.5" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="G" FontWeight="Bold" FontSize="20" Foreground="#4285F4" VerticalAlignment="Center" Margin="0,-2,14,0"/>
                            <TextBlock Text="Sign in with Google" FontWeight="Bold" Foreground="#1E293B" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Footer -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
                        <TextBlock Text="Don't have an account?" Foreground="#888888" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Contact your administrator" Foreground="#F44336" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
