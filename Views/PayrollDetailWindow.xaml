<Window
    x:Class="FastAccountingSoftware.Views.PayrollDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Payroll Run Details"
    Height="440" Width="460"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Border CornerRadius="16" Background="#FAF8F5" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Color="#000000" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" x:Name="HeaderBand" CornerRadius="14,14,0,0" Padding="24,20" Background="#1B2A1C" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="🗓" FontSize="26" Foreground="White"/>
                        <TextBlock x:Name="HeaderName" Text="Payroll Cycle" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                        <TextBlock x:Name="HeaderAmount" Text="₦0" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="#88FFFFFF" FontSize="14" BorderThickness="0" Cursor="Hand" Padding="4"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>
                    <!-- Status Badge -->
                    <Border x:Name="StatusBadge" CornerRadius="8" Padding="12,10" Margin="0,0,0,12" HorizontalAlignment="Left">
                        <TextBlock x:Name="StatusText" Text="Status" FontSize="13" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Staff Count -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="STAFF MEMBERS PAID" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <TextBlock x:Name="StaffCountText" Text="0 Employees" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </StackPanel>
                    </Border>

                    <!-- Date info -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="PAYMENT DATE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <TextBlock x:Name="DateText" Text="-" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,16" BorderBrush="#F1ECE7" BorderThickness="0,1,0,0">
                <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right"
                        Background="#1B2A1C" Foreground="White" Padding="24,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
            </Border>
        </Grid>
    </Border>
</Window>
