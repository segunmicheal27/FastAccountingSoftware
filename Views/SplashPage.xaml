<Page
    x:Class="FastAccountingSoftware.Views.SplashPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FFFDFB"
    FontFamily="Segoe UI Variable, Inter, Segoe UI">

    <Grid Background="#FFF8F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="42*" />
            <ColumnDefinition Width="58*" />
        </Grid.ColumnDefinitions>

        <!-- Wave Canvas populated dynamically from code-behind (Taller Guilloche mesh, height=320) -->
        <Viewbox Stretch="Fill" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Height="320">
            <Canvas x:Name="WaveCanvas" Width="1366" Height="320" />
        </Viewbox>

        <!-- LEFT COLUMN: Content -->
        <Grid Grid.Column="0" Margin="70,0,50,0" VerticalAlignment="Center">
            <StackPanel>
                
                <!-- Logo & Title (Using ImageBrush Viewbox to crop transparent whitespace) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,40">
                    <Border Width="70" Height="70" CornerRadius="35" Margin="0,0,16,0" VerticalAlignment="Center">
                        <Border.Background>
                            <ImageBrush ImageSource="pack://application:,,,/Assets/fas-without-text.png" 
                                        Stretch="UniformToFill" 
                                        Viewbox="0.32,0.32,0.36,0.36" />
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Direction="270" Color="#F44336" Opacity="0.25"/>
                        </Border.Effect>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Fast" Foreground="#F44336" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="Accounting" Foreground="#FF7A00" FontSize="28" FontWeight="Bold" Margin="4,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Software" Foreground="#1E293B" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Headline -->
                <TextBlock Text="Smart Accounting." FontSize="46" FontWeight="Bold" Foreground="#1E293B" />
                <TextBlock Text="Faster Business." FontSize="46" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                
                <!-- Title Gradient Divider (Width 90, Height 4, CornerRadius 2) -->
                <Border Width="90" Height="4" CornerRadius="2" Background="#FF6F00" HorizontalAlignment="Left" Margin="0,0,0,32"/>

                <!-- Subtitle -->
                <TextBlock Text="A unified accounting system that consolidates financial data, streamlines workflows, and delivers real-time insights across every transaction." 
                           TextWrapping="Wrap" FontSize="15" Foreground="#555555" LineHeight="24" Margin="0,0,0,40"/>

                <!-- Features List (Enlarged circles to 40x40 and icons to FontSize=18) -->
                <StackPanel Margin="0,0,0,60">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Grid Width="40" Height="40" Margin="0,0,16,0">
                            <Ellipse Fill="#FFF2EB" />
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="#F44336" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Smart automation for routine tasks" FontSize="14" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Grid Width="40" Height="40" Margin="0,0,16,0">
                            <Ellipse Fill="#FFF2EB" />
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" Foreground="#F44336" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Unified financial dashboards and reporting" FontSize="14" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="40" Height="40" Margin="0,0,16,0">
                            <Ellipse Fill="#FFF2EB" />
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#F44336" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Built for teams of any size" FontSize="14" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Loading Bar -->
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="Loading" FontWeight="Bold" FontSize="15" Foreground="#1E293B" Margin="0,0,8,0"/>
                            <TextBlock Text="Please wait while we prepare your workspace..." FontSize="13" Foreground="#888888" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                        </StackPanel>
                        <TextBlock x:Name="ProgressText" Text="0%" FontWeight="SemiBold" Foreground="#555555" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                    </Grid>
                    <ProgressBar x:Name="LoadingProgressBar" Maximum="100" Value="0" Height="6" Foreground="#F44336" Background="#eeeeee" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- RIGHT COLUMN: Relatable & High-Fidelity XAML Dashboard Preview -->
        <Grid Grid.Column="1" Margin="30,50,50,50" VerticalAlignment="Center">
            <!-- Main Mockup Container Card with Drop Shadow -->
            <Border Background="#FDFDFD" CornerRadius="20" Padding="28" BorderBrush="#F2EBE8" BorderThickness="1.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="35" ShadowDepth="6" Direction="270" Color="#000000" Opacity="0.10"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 1. Mockup Navigation bar (Clean Pill Tabs) -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <!-- Active Tab -->
                            <Border Background="#FFF2EB" CornerRadius="8" Padding="12,8,12,8" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#F44336" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dashboard" FontWeight="Bold" FontSize="13" Foreground="#F44336" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Inactive Tabs -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#94A3B8" Margin="8,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Transactions" FontSize="13" Foreground="#64748B" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                
                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#94A3B8" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Invoices" FontSize="13" Foreground="#64748B" Margin="0,0,16,0" VerticalAlignment="Center"/>

                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#94A3B8" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Customers" FontSize="13" Foreground="#64748B" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Profile representation -->
                        <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18" Background="#FFE6E2" BorderBrush="#FFC3B8" BorderThickness="1">
                            <TextBlock Text="JD" FontSize="12" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- 2. Dashboard Title & Quick Stats -->
                    <Grid Grid.Row="1" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Welcome back, John!" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="Here's your business financial overview for today." FontSize="13" Foreground="#64748B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#E2FBE7" CornerRadius="8" Padding="10,6,10,6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#10B981" VerticalAlignment="Center"/>
                                <TextBlock Text="Live Sync Active" FontSize="11" FontWeight="Bold" Foreground="#047857" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 3. Lower Content Area (Split into Line Chart and side stats) -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- TOP: Curved Revenue & Expenses Spline Graph Card -->
                        <Border Grid.Row="0" Background="White" CornerRadius="14" BorderBrush="#F0ECE8" BorderThickness="1.5" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.04"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Cashflow Performance" FontSize="14" FontWeight="Bold" Foreground="#475569"/>
                                        <TextBlock Text="Net Income: +$24,840.00" FontSize="18" FontWeight="Bold" Foreground="#10B981" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="#F44336" VerticalAlignment="Center"/>
                                        <TextBlock Text="Revenue" FontSize="11" Foreground="#64748B" Margin="6,0,16,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        
                                        <Ellipse Width="8" Height="8" Fill="#FF7A00" VerticalAlignment="Center"/>
                                        <TextBlock Text="Expenses" FontSize="11" Foreground="#64748B" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Curved charts using smooth spline lines -->
                                <Canvas Grid.Row="1" Margin="0,12,0,0" x:Name="ChartCanvas">
                                    <Canvas.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FDFDFD" Offset="0"/>
                                            <GradientStop Color="#FFFBF9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Canvas.Background>

                                    <!-- Grid Helper Lines -->
                                    <Line X1="0" Y1="25" X2="540" Y2="25" Stroke="#F3EFEA" StrokeThickness="1" StrokeDashArray="4 4" />
                                    <Line X1="0" Y1="65" X2="540" Y2="65" Stroke="#F3EFEA" StrokeThickness="1" StrokeDashArray="4 4" />
                                    <Line X1="0" Y1="105" X2="540" Y2="105" Stroke="#F3EFEA" StrokeThickness="1" StrokeDashArray="4 4" />

                                    <!-- Area Gradient Fill under Revenue Line -->
                                    <Path Data="M 10,95 Q 80,25 150,60 T 290,15 T 430,70 T 530,25 L 530,115 L 10,115 Z" Opacity="0.06">
                                        <Path.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#F44336" Offset="0"/>
                                                <GradientStop Color="#FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Fill>
                                    </Path>

                                    <!-- Revenue Curve (Red, smooth quadratic Bezier) -->
                                    <Path Data="M 10,95 Q 80,25 150,60 T 290,15 T 430,70 T 530,25" 
                                          Stroke="#F44336" StrokeThickness="3" Fill="Transparent" StrokeEndLineCap="Round" StrokeStartLineCap="Round" />

                                    <!-- Expenses Curve (Orange, smooth quadratic Bezier) -->
                                    <Path Data="M 10,110 Q 80,75 150,90 T 290,45 T 430,85 T 530,55" 
                                          Stroke="#FF7A00" StrokeThickness="2.5" Fill="Transparent" StrokeEndLineCap="Round" StrokeStartLineCap="Round" />

                                    <!-- Highlights at peak points -->
                                    <Ellipse Canvas.Left="286" Canvas.Top="11" Width="8" Height="8" Fill="#F44336" />
                                    <Ellipse Canvas.Left="526" Canvas.Top="21" Width="8" Height="8" Fill="#F44336" />
                                </Canvas>
                            </Grid>
                        </Border>

                        <!-- BOTTOM: Two Columns (Category Donut & Invoices) -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="58*" />
                            </Grid.ColumnDefinitions>

                            <!-- Donut Card (Expenses Breakdown) -->
                            <Border Grid.Column="0" Background="White" CornerRadius="14" BorderBrush="#F0ECE8" BorderThickness="1.5" Padding="16">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.04"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Expenses Breakdown" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                                    
                                    <!-- Donut Graph Layout -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Donut circle using layered StrokeDashArray ellipses -->
                                        <Canvas Grid.Column="0" Width="80" Height="80" VerticalAlignment="Center">
                                            <!-- Base/Salaries (Orange, 50%) -->
                                            <Ellipse Width="70" Height="70" StrokeThickness="14" Fill="Transparent" Canvas.Left="5" Canvas.Top="5"
                                                     StrokeDashArray="5.5 5.5" Stroke="#FF9A4D" />
                                            
                                            <!-- Rent (Red, 30%) -->
                                            <Ellipse Width="70" Height="70" StrokeThickness="14" Fill="Transparent" Canvas.Left="5" Canvas.Top="5"
                                                     StrokeDashArray="3.3 7.7" StrokeDashOffset="5.5" Stroke="#F44336" />
                                            
                                            <!-- Marketing/Others (Yellow, 20%) -->
                                            <Ellipse Width="70" Height="70" StrokeThickness="14" Fill="Transparent" Canvas.Left="5" Canvas.Top="5"
                                                     StrokeDashArray="2.2 8.8" StrokeDashOffset="8.8" Stroke="#FFD480" />
                                            
                                            <!-- Center hole text label -->
                                            <StackPanel Canvas.Left="20" Canvas.Top="25" Width="40" HorizontalAlignment="Center">
                                                <TextBlock Text="Total" FontSize="8" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                                <TextBlock Text="$9.4K" FontSize="11" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Canvas>

                                        <!-- Legend -->
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Ellipse Width="6" Height="6" Fill="#FF9A4D" VerticalAlignment="Center"/>
                                                <TextBlock Text="Salaries (50%)" FontSize="10" Foreground="#64748B" Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Ellipse Width="6" Height="6" Fill="#F44336" VerticalAlignment="Center"/>
                                                <TextBlock Text="Rent (30%)" FontSize="10" Foreground="#64748B" Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#FFD480" VerticalAlignment="Center"/>
                                                <TextBlock Text="Other (20%)" FontSize="10" Foreground="#64748B" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Invoices List Card -->
                            <Border Grid.Column="2" Background="White" CornerRadius="14" BorderBrush="#F0ECE8" BorderThickness="1.5" Padding="16">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.04"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Recent Invoices" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                                    
                                    <!-- Invoices Items Stack -->
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <!-- Row 1 -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="24" Height="24">
                                                <Ellipse Fill="#E2FBE7"/>
                                                <TextBlock Text="&#xE8EB;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Acme Corp" FontSize="12" FontWeight="Bold" Foreground="#1E293B"/>
                                                <TextBlock Text="INV-2026-001" FontSize="10" Foreground="#94A3B8"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="+$4,500.00" FontSize="12" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Row 2 -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="24" Height="24">
                                                <Ellipse Fill="#E2FBE7"/>
                                                <TextBlock Text="&#xE8EB;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Globex Ltd" FontSize="12" FontWeight="Bold" Foreground="#1E293B"/>
                                                <TextBlock Text="INV-2026-002" FontSize="10" Foreground="#94A3B8"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="+$2,800.00" FontSize="12" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Row 3 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="24" Height="24">
                                                <Ellipse Fill="#FFF2EB"/>
                                                <TextBlock Text="&#xE8C4;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#FF7A00" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Stark Ind" FontSize="12" FontWeight="Bold" Foreground="#1E293B"/>
                                                <TextBlock Text="INV-2026-003" FontSize="10" Foreground="#94A3B8"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="+$6,200.00" FontSize="12" FontWeight="Bold" Foreground="#FF7A00" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
