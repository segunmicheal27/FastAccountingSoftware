<Window x:Class="FastAccountingSoftware.Views.InventoryDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Details" Width="440" Height="500" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAF6EE">
    <Border Padding="24" CornerRadius="12" Background="White" Margin="12" BorderBrush="#E5E1D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#000000" Opacity="0.06"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Header -->
                <RowDefinition Height="*"/>    <!-- Details Content -->
                <RowDefinition Height="Auto"/> <!-- Footer Actions -->
            </Grid.RowDefinitions>

            <!-- Header with Title & SKU -->
            <Grid Grid.Row="0" Margin="0,0,0,20" MouseDown="Header_MouseDown" Background="Transparent">
                <StackPanel>
                    <TextBlock x:Name="ProductNameText" Text="Product Title" FontFamily="Georgia, Serif" FontSize="22" FontWeight="Bold" Foreground="#1B2A1C" TextWrapping="Wrap"/>
                    <Border x:Name="StatusBadge" CornerRadius="12" Padding="8,4" HorizontalAlignment="Left" Margin="0,8,0,0">
                        <TextBlock x:Name="StatusText" Text="In Stock" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Details List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Quantity in Stock -->
                    <Border Background="#FAF6F0" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📦" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="QUANTITY IN STOCK" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="QuantityText" Text="0 units" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Cost Price & Selling Price Row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Cost Price -->
                        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="UNIT COST" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                <TextBlock x:Name="CostPriceText" Text="₦0" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Border>

                        <!-- Selling Price -->
                        <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="SELLING PRICE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                <TextBlock x:Name="SellingPriceText" Text="₦0" FontSize="16" FontWeight="Bold" Foreground="#1B2A1C"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Profit Margin Card -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="ESTIMATED MARGIN PROFIT" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="ProfitMarginText" Text="₦0.00 (0.0% markup)" FontSize="14" FontWeight="SemiBold" Foreground="#2E7D32"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Reorder Warning Alert Level -->
                    <Border Background="White" CornerRadius="10" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔔" FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="REORDER WARNING LEVEL" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <TextBlock x:Name="ReorderLevelText" Text="5 units" FontSize="14" Foreground="#1E293B"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Dynamic Attributes Header & Container -->
                    <StackPanel x:Name="DynamicAttributesSection" Visibility="Collapsed" Margin="0,16,0,0">
                        <TextBlock Text="CUSTOM SPREADSHEET COLUMNS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <StackPanel x:Name="DynamicAttributesContainer">
                            <!-- Populated dynamically -->
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Actions -->
            <Border Grid.Row="2" Padding="0,16,0,0" BorderBrush="#F1ECE7" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="⚡ Restock" Click="Restock_Click" Background="#E8F5E9" Foreground="#2E7D32" BorderBrush="#A5D6A7" BorderThickness="1" Padding="16,8" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,8,0"/>
                        <Button Content="Edit" Click="Edit_Click" Background="#FF7A00" Foreground="White" BorderThickness="0" Padding="20,8" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>
                    <Button Content="Close" Click="Close_Click" Background="#1B2A1C" Foreground="White" BorderThickness="0" Padding="24,8" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
